############################################
# Node.js build stage
############################################
FROM node:24-bookworm-slim AS build
USER node
WORKDIR /app

ENV PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=1
COPY --chown=node:node .npmrc .npmrc
COPY --chown=node:node package.json package.json
COPY --chown=node:node package-lock.json package-lock.json
RUN npm ci --omit=dev
COPY . .
RUN mkdir ./data

############################################
# ⭐ Main Image (rootless by default)
############################################
FROM node:24-bookworm-slim AS release
WORKDIR /app

LABEL org.opencontainers.image.source="https://github.com/lleirborras/uptime-panda"

# dumb-init: clean signal handling / zombie reaping
# iputils-ping: ping monitor type
# curl: healthcheck + in-container debugging
RUN apt-get update \
    && apt-get install --yes --no-install-recommends \
        dumb-init \
        iputils-ping \
        curl \
    && rm -rf /var/lib/apt/lists/*

ENV UPTIME_KUMA_IS_CONTAINER=1

COPY --chown=node:node --from=build /app /app

USER node

EXPOSE 3001
HEALTHCHECK --interval=60s --timeout=30s --start-period=180s --retries=5 \
    CMD curl -f --max-time 28 --insecure http://127.0.0.1:3001 || exit 1
ENTRYPOINT ["/usr/bin/dumb-init", "--"]
CMD ["node", "server/server.js"]

############################################
# Root variant (opt-in, for environments that need CAP_NET_RAW ping
# without explicit capability grants or other root-only features)
############################################
FROM release AS root
USER root
